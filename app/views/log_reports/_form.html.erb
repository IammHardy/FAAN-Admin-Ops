<%= form_with model: @log_report, class: "space-y-6" do |f| %>
  <% if @log_report.errors.any? %>
    <div class="border border-red-300 bg-red-50 p-4 text-sm text-red-800">
      <p class="font-semibold mb-2">Please fix the following errors:</p>
      <ul class="list-disc ml-5 space-y-1">
        <% @log_report.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <%= f.label :report_date, class: "block text-sm font-medium mb-1" %>
        <%= f.date_field :report_date, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :shift, class: "block text-sm font-medium mb-1" %>
        <%= f.select :shift,
            LogReport.shifts.keys.map { |shift| [shift.humanize, shift] },
            { prompt: "Select Shift" },
            class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :department_id, "Department", class: "block text-sm font-medium mb-1" %>
        <%= f.collection_select :department_id, @departments, :id, :name,
            { prompt: "Select Department" },
            { class: "w-full border border-gray-300 px-3 py-2 text-sm" } %>
      </div>

      <div>
        <%= f.label :unit_id, "Unit", class: "block text-sm font-medium mb-1" %>
        <%= f.collection_select :unit_id, @units, :id, :name,
            { prompt: "Select Unit" },
            { class: "w-full border border-gray-300 px-3 py-2 text-sm" } %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :summary, class: "block text-sm font-medium mb-1" %>
        <%= f.text_area :summary, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
      </div>

      <div class="md:col-span-2">
        <%= f.label :general_remarks, class: "block text-sm font-medium mb-1" %>
        <%= f.text_area :general_remarks, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
      </div>
    </div>
  </div>

  <div class="md:col-span-2">
  <%= f.label :source_document, "Attach Source Log Sheet", class: "block text-sm font-medium mb-1" %>
  <%= f.file_field :source_document, class: "w-full border border-gray-300 px-3 py-2 text-sm bg-white" %>

  <% if @log_report.persisted? && @log_report.source_document.attached? %>
  <p class="text-xs text-gray-500 mt-2">
    Current file:
    <%= link_to @log_report.source_document.filename.to_s,
        rails_blob_path(@log_report.source_document, disposition: "attachment"),
        class: "text-blue-600 hover:underline" %>
  </p>
<% end %>
</div>


  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
    <%= link_to "Cancel", log_reports_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
<% end %>