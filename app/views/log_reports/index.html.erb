<% content_for :page_title, "Daily Log Reports" %>
<% content_for :page_subtitle, "Manage daily logs submitted by departments and units." %>

<div class="flex items-center justify-between mb-4">
  <div></div>
  <% if can_manage_logs? %>
  <%= link_to "New Log Report", new_log_report_path, class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
<% end %>
</div>



<div class="bg-white border border-gray-200 overflow-x-auto">
  <% if @log_reports.any? %>
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold">Date</th>
          <th class="text-left px-4 py-3 font-semibold">Shift</th>
          <th class="text-left px-4 py-3 font-semibold">Department</th>
          <th class="text-left px-4 py-3 font-semibold">Unit</th>
          <th class="text-left px-4 py-3 font-semibold">Entered By</th>
          <th class="text-left px-4 py-3 font-semibold">Status</th>
          <th class="text-right px-4 py-3 font-semibold">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @log_reports.each do |log_report| %>
          <tr class="border-b border-gray-100">
            <td class="px-4 py-3"><%= log_report.report_date&.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3"><%= log_report.shift.humanize %></td>
            <td class="px-4 py-3"><%= log_report.department.name %></td>
            <td class="px-4 py-3"><%= log_report.unit.name %></td>
            <td class="px-4 py-3"><%= log_report.entered_by.display_name %></td>
            <td class="px-4 py-3">
              <span class="inline-block px-2 py-1 text-xs border
                <%= case log_report.status
                    when 'draft'
                      'bg-gray-50 border-gray-300 text-gray-700'
                    when 'submitted'
                      'bg-blue-50 border-blue-300 text-blue-700'
                    when 'reviewed'
                      'bg-green-50 border-green-300 text-green-700'
                    end %>">
                <%= log_report.status.humanize %>
              </span>
            </td>
           <td class="px-4 py-3 text-right space-x-2">
  <%= link_to "View", log_report_path(log_report), class: "text-blue-600 hover:underline" %>

  <% if current_user.reviewer? && log_report.submitted? %>
    <%= link_to "Review",
        review_log_report_path(log_report),
        data: { turbo_method: :patch, turbo_confirm: "Mark this log report as reviewed?" },
        class: "text-green-700 hover:underline" %>
  <% end %>

  <%= link_to "Print",
      print_log_report_path(log_report),
      target: "_blank",
      class: "text-slate-700 hover:underline" %>

  <% if can_manage_logs? %>
    <%= link_to "Edit", edit_log_report_path(log_report), class: "text-amber-600 hover:underline" %>
  <% end %>

  <% if can_delete_logs? %>
    <%= button_to "Delete",
        log_report_path(log_report),
        method: :delete,
        form: { class: "inline-block" },
        data: { turbo_confirm: "Are you sure you want to delete this log report?" },
        class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
  <% end %>
</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-sm text-gray-500">
      No log reports found.
    </div>
  <% end %>
  <div class="mt-6">
  <%= paginate @log_reports %>
</div>
</div>