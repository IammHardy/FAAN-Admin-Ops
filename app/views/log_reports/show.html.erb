<% content_for :page_title, "Log Report" %>
<% content_for :page_subtitle, "#{@log_report.unit.name} • #{@log_report.report_date.strftime('%d %b %Y')}" %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-white border border-gray-200 p-6">
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <dt class="text-sm font-semibold text-gray-500">Report Date</dt>
          <dd class="mt-1 text-sm"><%= @log_report.report_date.strftime("%d %b %Y") %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Shift</dt>
          <dd class="mt-1 text-sm"><%= @log_report.shift.humanize %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Department</dt>
          <dd class="mt-1 text-sm"><%= @log_report.department.name %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Unit</dt>
          <dd class="mt-1 text-sm"><%= @log_report.unit.name %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Entered By</dt>
          <dd class="mt-1 text-sm"><%= @log_report.entered_by.display_name %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Submitted By</dt>
          <dd class="mt-1 text-sm"><%= @log_report.submitted_by&.display_name || "-" %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Status</dt>
          <dd class="mt-1 text-sm"><%= @log_report.status.humanize %></dd>
        </div>

        <div>
          <dt class="text-sm font-semibold text-gray-500">Created At</dt>
          <dd class="mt-1 text-sm"><%= @log_report.created_at.strftime("%d %b %Y, %I:%M %p") %></dd>
        </div>

        <div class="md:col-span-2">
          <dt class="text-sm font-semibold text-gray-500">Summary</dt>
          <dd class="mt-1 text-sm text-gray-700"><%= @log_report.summary.presence || "No summary provided." %></dd>
        </div>

        <div class="md:col-span-2">
          <dt class="text-sm font-semibold text-gray-500">General Remarks</dt>
          <dd class="mt-1 text-sm text-gray-700"><%= @log_report.general_remarks.presence || "No remarks provided." %></dd>
        </div>
      </dl>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <%= link_to "Edit", edit_log_report_path(@log_report), class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 text-sm font-medium" %>
        <%= link_to "Print", print_log_report_path(@log_report), class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
        <%= link_to "Back", log_reports_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      </div>
    </div>

    <div class="bg-white border border-gray-200 p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-base font-semibold">Log Entries</h3>
      </div>

      <% if @log_entries.any? %>
        <div class="space-y-4">
          <% @log_entries.each do |entry| %>
            <div class="border border-gray-200 p-4">
              <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                <div class="text-sm font-medium">
                  <%= entry.entry_time&.strftime("%I:%M %p") || "-" %>
                </div>
                <div class="flex items-center gap-2">
                  <% if entry.incident_flag? %>
                    <span class="inline-block px-2 py-1 text-xs border bg-red-50 border-red-300 text-red-700">Incident</span>
                  <% end %>
                  <% if entry.follow_up_needed? %>
                    <span class="inline-block px-2 py-1 text-xs border bg-amber-50 border-amber-300 text-amber-700">Follow-up Needed</span>
                  <% end %>
                </div>
              </div>

              <p class="text-sm text-gray-800 mb-2"><%= entry.description %></p>

              <p class="text-sm text-gray-600">
                <strong>Action Taken:</strong> <%= entry.action_taken.presence || "-" %>
              </p>

              <div class="mt-3 flex flex-wrap items-center gap-3">
                <%= link_to "Edit", edit_log_report_log_entry_path(@log_report, entry), class: "text-amber-600 hover:underline text-sm" %>

                <% unless entry.incident.present? %>
                  <% if entry.incident_flag? %>
                    <%= link_to "Create Incident",
                        new_incident_path(log_report_id: @log_report.id, log_entry_id: entry.id),
                        class: "text-blue-600 hover:underline text-sm" %>
                  <% end %>
                <% else %>
                  <%= link_to "View Incident", incident_path(entry.incident), class: "text-green-600 hover:underline text-sm" %>
                <% end %>

                <%= button_to "Delete",
                    log_report_log_entry_path(@log_report, entry),
                    method: :delete,
                    form: { class: "inline-block" },
                    data: { turbo_confirm: "Are you sure you want to delete this log entry?" },
                    class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer text-sm" %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No log entries added yet.</p>
      <% end %>
    </div>

    <div class="md:col-span-2">
  <dt class="text-sm font-semibold text-gray-500">Attached Source Log Sheet</dt>
  <dd class="mt-1 text-sm text-gray-700">
    <% if @log_report.source_document.attached? %>
      <%= link_to @log_report.source_document.filename.to_s,
          rails_blob_path(@log_report.source_document, disposition: "attachment"),
          class: "text-blue-600 hover:underline" %>
    <% else %>
      No source document attached.
    <% end %>
  </dd>
</div>

<div class="mt-6 bg-white border border-gray-200 p-6">
  <h3 class="text-base font-semibold mb-4">Activity History</h3>

  <% if @audit_logs.any? %>
    <div class="space-y-3">
      <% @audit_logs.each do |log| %>
        <div class="border-b border-gray-100 pb-3 last:border-b-0">
          <p class="text-sm font-medium"><%= log.description %></p>
          <p class="text-xs text-gray-500 mt-1">
            <%= log.user.display_name %> • <%= log.created_at.strftime("%d %b %Y, %I:%M %p") %>
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">No activity history for this dispatch.</p>
  <% end %>
</div>

    <div class="bg-white border border-gray-200 p-6">
      <h3 class="text-base font-semibold mb-4">Incidents from this Report</h3>

      <% if @incidents.any? %>
        <div class="space-y-3">
          <% @incidents.each do |incident| %>
            <div class="border border-gray-200 p-4">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="font-medium"><%= link_to incident.incident_number, incident_path(incident), class: "hover:underline" %></p>
                  <p class="text-sm text-gray-600"><%= incident.title %></p>
                </div>

                <div class="text-right">
                  <p class="text-sm"><%= incident.severity.humanize %></p>
                  <p class="text-xs text-gray-500"><%= incident.status.humanize %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No incidents created from this report yet.</p>
      <% end %>
    </div>
  </div>

  <div class="space-y-6">
    <div class="bg-white border border-gray-200 p-6">
      <h3 class="text-base font-semibold mb-4">Report Actions</h3>

      <div class="space-y-3">
        <% if @log_report.draft? %>
          <%= button_to "Submit Report",
              submit_report_log_report_path(@log_report),
              method: :patch,
              class: "w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 text-sm font-medium" %>
        <% end %>

        <% if @log_report.submitted? %>
          <%= button_to "Mark as Reviewed",
              review_log_report_path(@log_report),
              method: :patch,
              class: "w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 text-sm font-medium" %>
        <% end %>
      </div>
    </div>
<% if can_manage_logs? && @log_report.draft? %>
    <div class="bg-white border border-gray-200 p-6">
      <h3 class="text-base font-semibold mb-4">Quick Add Log Entry</h3>

      <%= form_with model: [@log_report, LogEntry.new], local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :entry_time, class: "block text-sm font-medium mb-1" %>
          <%= f.time_field :entry_time, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-medium mb-1" %>
          <%= f.text_area :description, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :action_taken, class: "block text-sm font-medium mb-1" %>
          <%= f.text_area :action_taken, rows: 2, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <%= f.check_box :incident_flag, class: "border-gray-300" %>
            <%= f.label :incident_flag, "Incident", class: "text-sm" %>
          </div>

          <div class="flex items-center gap-2">
            <%= f.check_box :follow_up_needed, class: "border-gray-300" %>
            <%= f.label :follow_up_needed, "Follow-up", class: "text-sm" %>
          </div>
        </div>

        <%= f.submit "Add Entry", class: "w-full bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
      <% end %>
    </div>
    <% end %>
  </div>
</div>