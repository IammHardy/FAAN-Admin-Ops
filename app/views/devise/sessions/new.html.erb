<div class="min-h-screen grid grid-cols-1 lg:grid-cols-2">
  <div class="hidden lg:flex bg-slate-950 text-white px-12 py-16 flex-col justify-between">
    <div>
      <p class="text-sm uppercase tracking-[0.2em] text-slate-400">FAAN Internal System</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight">
        FAAN Admin <br>
        Operations System
      </h1>
      <p class="mt-6 text-base text-slate-300 max-w-md leading-7">
        A centralized internal platform for dispatch tracking, daily log reports,
        incident management, and operational record keeping.
      </p>
    </div>

    <div class="space-y-4">
      <div class="border border-slate-800 bg-slate-900 px-5 py-4">
        <h3 class="text-sm font-semibold text-white">Dispatch Tracking</h3>
        <p class="mt-1 text-sm text-slate-400">
          Track internal memos and document movement across departments.
        </p>
      </div>

      <div class="border border-slate-800 bg-slate-900 px-5 py-4">
        <h3 class="text-sm font-semibold text-white">Daily Log Reports</h3>
        <p class="mt-1 text-sm text-slate-400">
          Capture and review daily operational logs by unit and shift.
        </p>
      </div>

      <div class="border border-slate-800 bg-slate-900 px-5 py-4">
        <h3 class="text-sm font-semibold text-white">Incident Reporting</h3>
        <p class="mt-1 text-sm text-slate-400">
          Extract incidents, escalate them, and maintain accountability records.
        </p>
      </div>
    </div>
  </div>

  <div class="bg-white flex items-center justify-center px-6 py-10">
    <div class="w-full max-w-md">
      <div class="bg-white border border-slate-300 shadow-md px-8 py-8">
        <div class="mb-8">
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Sign in</h2>
          <p class="mt-2 text-sm text-slate-600">
            Enter your credentials to access the FAAN Admin Operations System.
          </p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  class: "w-full border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-slate-900" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  class: "w-full border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-slate-900" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "h-4 w-4 border border-slate-300" %>
              <%= f.label :remember_me, class: "text-sm text-slate-600" %>
            </div>
          <% end %>

          <div>
            <%= f.submit "Sign in",
                  class: "w-full inline-flex items-center justify-center bg-slate-900 hover:bg-black text-white text-sm font-medium px-4 py-2 transition" %>
          </div>
        <% end %>

        <div class="mt-6 text-sm">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>