<% content_for :page_title, "Departments" %>
<% content_for :page_subtitle, "Manage airport departments." %>

<div class="flex items-center justify-between mb-4">
  <div></div>
  <%= link_to "New Department", new_department_path, class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
</div>

<div class="bg-white border border-gray-200 overflow-hidden">
  <% if @departments.any? %>
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold">Name</th>
          <th class="text-left px-4 py-3 font-semibold">Description</th>
          <th class="text-left px-4 py-3 font-semibold">Status</th>
          <th class="text-right px-4 py-3 font-semibold">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @departments.each do |department| %>
          <tr class="border-b border-gray-100">
            <td class="px-4 py-3"><%= department.name %></td>
            <td class="px-4 py-3 text-gray-600"><%= department.description.presence || "-" %></td>
            <td class="px-4 py-3">
              <span class="inline-block px-2 py-1 text-xs border <%= department.active? ? 'bg-green-50 border-green-300 text-green-700' : 'bg-red-50 border-red-300 text-red-700' %>">
                <%= department.active? ? "Active" : "Inactive" %>
              </span>
            </td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to "View", department_path(department), class: "text-blue-600 hover:underline" %>
              <%= link_to "Edit", edit_department_path(department), class: "text-amber-600 hover:underline" %>
              <%= button_to "Delete",
                  department_path(department),
                  method: :delete,
                  form: { class: "inline-block" },
                  data: { turbo_confirm: "Are you sure you want to delete this department?" },
                  class: "text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-sm text-gray-500">
      No departments found.
    </div>
  <% end %>
</div>