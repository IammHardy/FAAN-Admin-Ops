<% content_for :page_title, "My Account" %>
<% content_for :page_subtitle, "Update your profile details and password." %>

<div class="max-w-2xl bg-white border border-gray-200 p-6">
  <% if @user.errors.any? %>
    <div class="border border-red-300 bg-red-50 p-4 text-sm text-red-800 mb-5">
      <p class="font-semibold mb-2">Please fix the following errors:</p>

      <ul class="list-disc ml-5 space-y-1">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-5" do |f| %>
    <div>
      <%= f.label :full_name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :full_name, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="border-t border-gray-200 pt-5">
      <h3 class="text-base font-semibold mb-1">Change Password</h3>
      <p class="text-sm text-gray-500 mb-4">
        Leave password fields blank if you do not want to change your password.
      </p>

      <div class="space-y-4">
        <div>
          <%= f.label :current_password, class: "block text-sm font-medium mb-1" %>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :password, "New Password", class: "block text-sm font-medium mb-1" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm New Password", class: "block text-sm font-medium mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit "Update Account", class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
      <%= link_to "Back to Dashboard", dashboard_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>