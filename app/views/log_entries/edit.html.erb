<% content_for :page_title, "Edit Log Entry" %>
<% content_for :page_subtitle, "Update this log entry before submission." %>

<div class="bg-white border border-gray-200 p-6 max-w-3xl">
  <%= form_with model: [@log_report, @log_entry], local: true do |form| %>
    <div class="mb-4">
      <%= form.label :entry_time, class: "block text-sm font-medium mb-1" %>
      <%= form.datetime_field :entry_time, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="mb-4">
      <%= form.label :description, class: "block text-sm font-medium mb-1" %>
      <%= form.text_area :description, rows: 5, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="mb-4">
      <%= form.label :action_taken, class: "block text-sm font-medium mb-1" %>
      <%= form.text_area :action_taken, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex items-center gap-4 mb-4">
      <label class="text-sm">
        <%= form.check_box :incident_flag %>
        Incident?
      </label>

      <label class="text-sm">
        <%= form.check_box :follow_up_needed %>
        Follow-up needed?
      </label>
    </div>

    <div class="flex gap-3">
      <%= form.submit "Update Entry", class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
      <%= link_to "Cancel", log_report_path(@log_report), class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>