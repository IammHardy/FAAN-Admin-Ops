<% content_for :page_title, "Notifications" %>
<% content_for :page_subtitle, "View your recent system alerts and updates." %>

<div class="bg-white border border-gray-200">
  <% if @notifications.any? %>
    <div class="divide-y divide-gray-200">
      <% @notifications.each do |notification| %>
        <div class="p-4 <%= notification.read? ? 'bg-white' : 'bg-blue-50' %>">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-gray-900">
                <%= notification.title %>
              </h3>

              <p class="text-sm text-gray-600 mt-1">
                <%= notification.message %>
              </p>

              <p class="text-xs text-gray-400 mt-2">
                <%= notification.created_at.strftime("%d %b %Y, %I:%M %p") %>
              </p>
            </div>

            <% unless notification.read? %>
              <%= button_to "Mark as read",
                  mark_as_read_notification_path(notification),
                  method: :patch,
                  class: "text-xs border border-gray-300 px-3 py-1 bg-white hover:bg-gray-50" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-6 text-sm text-gray-500">
      You have no notifications yet.
    </div>
  <% end %>
  <div class="mt-6">
  <%= paginate @notifications %>
</div>
</div>