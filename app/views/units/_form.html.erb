<%= form_with model: @unit, class: "space-y-5" do |f| %>
  <% if @unit.errors.any? %>
    <div class="border border-red-300 bg-red-50 p-4 text-sm text-red-800">
      <p class="font-semibold mb-2">Please fix the following errors:</p>
      <ul class="list-disc ml-5 space-y-1">
        <% @unit.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :department_id, "Department", class: "block text-sm font-medium mb-1" %>
    <%= f.collection_select :department_id, @departments, :id, :name,
        { prompt: "Select Department" },
        { class: "w-full border border-gray-300 px-3 py-2 text-sm" } %>
  </div>

  <div>
    <%= f.label :name, "Unit Name", class: "block text-sm font-medium mb-1" %>
    <%= f.text_field :name, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "border-gray-300" %>
    <%= f.label :active, "Active", class: "text-sm font-medium" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
    <%= link_to "Cancel", units_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
<% end %>