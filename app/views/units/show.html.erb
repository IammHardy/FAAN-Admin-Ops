<% content_for :page_title, @unit.name %>
<% content_for :page_subtitle, "Unit details." %>

<div class="bg-white border border-gray-200 p-6 max-w-3xl">
  <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <dt class="text-sm font-semibold text-gray-500">Department</dt>
      <dd class="mt-1 text-sm"><%= @unit.department.name %></dd>
    </div>

    <div>
      <dt class="text-sm font-semibold text-gray-500">Unit Name</dt>
      <dd class="mt-1 text-sm"><%= @unit.name %></dd>
    </div>

    <div>
      <dt class="text-sm font-semibold text-gray-500">Status</dt>
      <dd class="mt-1 text-sm"><%= @unit.active? ? "Active" : "Inactive" %></dd>
    </div>

    <div>
      <dt class="text-sm font-semibold text-gray-500">Created At</dt>
      <dd class="mt-1 text-sm"><%= @unit.created_at.strftime("%d %b %Y, %I:%M %p") %></dd>
    </div>

    <div class="md:col-span-2">
      <dt class="text-sm font-semibold text-gray-500">Description</dt>
      <dd class="mt-1 text-sm text-gray-700"><%= @unit.description.presence || "No description provided." %></dd>
    </div>

    <div>
      <dt class="text-sm font-semibold text-gray-500">Last Updated</dt>
      <dd class="mt-1 text-sm"><%= @unit.updated_at.strftime("%d %b %Y, %I:%M %p") %></dd>
    </div>
  </dl>

  <div class="mt-6 flex items-center gap-3">
    <%= link_to "Edit", edit_unit_path(@unit), class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 text-sm font-medium" %>
    <%= link_to "Back", units_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
</div>