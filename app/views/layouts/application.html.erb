<!DOCTYPE html>
<html>
  <head>
    <title>FAAN Admin Operations System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
  .app-shell {
    min-height: 100vh;
  }

 .app-sidebar {
  position: relative;
  top: auto;
  left: auto;
  width: 100%;
  max-height: 0;
  overflow: hidden;
  z-index: 40;
  transition: max-height 0.3s ease;
}

.app-sidebar.open {
  max-height: 80vh;
  overflow-y: auto;
}

@media (min-width: 768px) {
  .app-shell {
    display: flex;
  }

  .app-sidebar {
    position: sticky;
    top: 0;
    left: 0;
    width: 16rem;
    height: 100vh;
    max-height: none;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .app-content {
    flex: 1;
  }

  #sidebar-open,
  #sidebar-overlay,
  #sidebar-close {
    display: none !important;
  }
}
</style>
  </head>

  <body class="bg-gray-100 text-gray-900 min-h-screen">
    <div class="app-shell">
      <% if user_signed_in? %>
        <!-- Mobile Overlay -->
        <div
          id="sidebar-overlay"
          class="fixed inset-0 bg-black/50 z-30 hidden md:hidden">
        </div>

        <!-- Shared Sidebar -->
        <aside id="sidebar" class="app-sidebar bg-slate-900 text-white flex flex-col">

          <div class="px-6 py-6 border-b border-slate-700 flex items-start justify-between gap-4">
  <div>
    <h1 class="text-lg font-bold">FAAN Admin Ops</h1>
    <p class="text-sm text-slate-300 mt-1">Operations Support System</p>
  </div>

  <button
    type="button"
    id="sidebar-close"
    class="md:hidden border border-slate-600 px-2 py-1 text-sm hover:bg-slate-800">
    X
  </button>
</div>

          <nav class="flex-1 px-4 py-4 space-y-2 text-sm overflow-y-auto">
            <%= link_to "Dashboard", dashboard_path, class: nav_link_class(dashboard_path) %>

            <% if current_user.super_admin? || current_user.admin_officer? %>
              <%= link_to "Departments", departments_path, class: nav_link_class(departments_path) %>
              <%= link_to "Units", units_path, class: nav_link_class(units_path) %>
              <%= link_to "Users", users_path, class: nav_link_class(users_path) %>
              <%= link_to "Audit Logs", audit_logs_path, class: nav_link_class(audit_logs_path) %>
            <% end %>

            <% if current_user.unit_officer? %>
              <%= link_to "Incoming Memos", incoming_dispatches_path, class: nav_link_class(incoming_dispatches_path) %>
            <% end %>

            <% if current_user.super_admin? || current_user.admin_officer? || current_user.unit_officer? || current_user.reviewer? %>
              <%= link_to "Daily Logs", log_reports_path, class: nav_link_class(log_reports_path) %>
            <% end %>

            <% if current_user.dispatch_officer? || current_user.admin_officer? || current_user.super_admin? %>
              <%= link_to "Dispatch Register", dispatches_path, class: nav_link_class(dispatches_path) %>
              <%= link_to "New Dispatch", new_dispatch_path, class: nav_link_class(new_dispatch_path) %>
              <%= link_to "Pending Acknowledgements", pending_acknowledgement_dispatches_path, class: nav_link_class(pending_acknowledgement_dispatches_path) %>
              <%= link_to "Ready to File", ready_to_file_dispatches_path, class: nav_link_class(ready_to_file_dispatches_path) %>
              <%= link_to "Filed Dispatches", filed_dispatches_path, class: nav_link_class(filed_dispatches_path) %>
            <% end %>

            <% if current_user.super_admin? || current_user.admin_officer? || current_user.reviewer? %>
              <%= link_to "Incidents", incidents_path, class: nav_link_class(incidents_path) %>
              <%= link_to "Reports", reports_dispatches_path, class: nav_link_class(reports_dispatches_path) %>
            <% end %>

            <% if current_user.super_admin? || current_user.admin_officer? %>
  <%= link_to "Minutes Extraction", minutes_path, class: nav_link_class(minutes_path) %>
<% end %>

         <% unread_count = current_user.notifications.unread.count %>

<%= link_to notifications_path, class: "relative" do %>
  🔔

  <% if unread_count.positive? %>
    <span class="absolute -top-2 -right-2 bg-red-600 text-white text-xs rounded-full px-1.5 py-0.5">
      <%= unread_count %>
    </span>
  <% end %>
<% end %>
          </nav>

          <%= link_to "My Account",
    edit_account_path,
    class: "block w-full text-center border border-slate-600 text-white px-4 py-2 text-sm font-medium hover:bg-slate-800 mb-2" %>

          <div class="px-4 py-4 border-t border-slate-700 text-sm">
            <p class="font-semibold"><%= current_user.display_name %></p>
            <p class="text-slate-300 capitalize"><%= current_user.role.humanize %></p>

            <div class="mt-4">
              <%= button_to "Sign Out",
                  destroy_user_session_path,
                  method: :delete,
                  class: "w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium" %>
            </div>
          </div>
        </aside>
      <% end %>

      <!-- Main Content -->
      <div class="app-content">
        <% if user_signed_in? %>
 <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4 flex items-center justify-between gap-4">
  <div>
    <h2 class="text-lg md:text-xl font-semibold">
      <%= content_for?(:page_title) ? yield(:page_title) : "FAAN Admin Operations System" %>
    </h2>

    <% if content_for?(:page_subtitle) %>
      <p class="text-sm text-gray-500 mt-1"><%= yield(:page_subtitle) %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-2">
    <% unread_notifications_count = current_user.notifications.unread.count %>

    <%= link_to notifications_path, class: "relative text-sm border border-gray-300 px-3 py-2 bg-white hover:bg-gray-50" do %>
      🔔
      <% if unread_notifications_count.positive? %>
        <span class="absolute -top-2 -right-2 bg-red-600 text-white text-xs px-1.5 py-0.5 rounded-full">
          <%= unread_notifications_count %>
        </span>
      <% end %>
    <% end %>

    <button
      type="button"
      id="sidebar-open"
      class="md:hidden inline-flex items-center justify-center border border-gray-300 px-3 py-2 text-sm bg-white hover:bg-gray-100">
      ☰
    </button>
  </div>
</header>
        <% end %>

        <main class="px-4 md:px-6 py-6">
          <% flash.each do |type, message| %>
            <div class="<%= flash_class(type) %> mb-4 px-4 py-3 border text-sm">
              <%= message %>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>
    </div>

  <script>
  function setupSidebarMenu() {
    const sidebar = document.getElementById("sidebar");
    const openButton = document.getElementById("sidebar-open");
    const closeButton = document.getElementById("sidebar-close");
    const overlay = document.getElementById("sidebar-overlay");

    if (!sidebar || !openButton || !closeButton || !overlay) return;

    function openSidebar() {
      sidebar.classList.add("open");
      overlay.classList.remove("hidden");
    }

    function closeSidebar() {
      sidebar.classList.remove("open");
      overlay.classList.add("hidden");
    }

    openButton.onclick = openSidebar;
    closeButton.onclick = closeSidebar;
    overlay.onclick = closeSidebar;

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") closeSidebar();
    });

    window.addEventListener("resize", function () {
      if (window.innerWidth >= 768) closeSidebar();
    });
  }

  document.addEventListener("DOMContentLoaded", setupSidebarMenu);
  document.addEventListener("turbo:load", setupSidebarMenu);
</script>
  </body>
</html>