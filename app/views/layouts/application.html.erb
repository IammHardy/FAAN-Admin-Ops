<!DOCTYPE html>
<html>
  <head>
    <title>FAAN Admin Operations System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      @media (min-width: 768px) {
        .mobile-only { display: none !important; }
        .desktop-sidebar { display: flex !important; }
      }

      @media (max-width: 767px) {
        .desktop-sidebar { display: none !important; }
      }
    </style>
  </head>

  <body class="bg-gray-100 text-gray-900 min-h-screen">
    <% if user_signed_in? %>
      <!-- Mobile Header -->
      <header class="mobile-only flex bg-slate-900 text-white px-4 py-3 items-center justify-between">
        <div>
          <h1 class="text-base font-bold">FAAN Admin Ops</h1>
          <p class="text-xs text-slate-300"><%= current_user.role.humanize %></p>
        </div>

        <button
          type="button"
          id="mobile-menu-button"
          class="border border-slate-600 px-3 py-2 text-sm bg-slate-800 hover:bg-slate-700">
          Menu
        </button>
      </header>

      <div id="mobile-overlay" class="mobile-only hidden fixed inset-0 bg-black/50 z-40"></div>

      <!-- Mobile Sidebar -->
      <aside
        id="mobile-sidebar"
        class="mobile-only fixed left-0 top-0 h-screen w-64 bg-slate-900 text-white z-50 -translate-x-full transition-transform duration-300 flex flex-col">

        <div class="px-4 py-4 border-b border-slate-700 flex items-center justify-between">
          <div>
            <h1 class="text-base font-bold">FAAN Admin Ops</h1>
            <p class="text-xs text-slate-300">Operations Support</p>
          </div>

          <button type="button" id="mobile-menu-close" class="text-sm border border-slate-600 px-2 py-1">
            X
          </button>
        </div>

        <nav class="flex-1 px-3 py-3 space-y-2 text-sm overflow-y-auto">
          <%= link_to "Dashboard", dashboard_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>

          <% if current_user.super_admin? || current_user.admin_officer? %>
            <%= link_to "Departments", departments_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Units", units_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Users", users_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Audit Logs", audit_logs_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
          <% end %>

          <% if current_user.unit_officer? %>
            <%= link_to "Incoming Memos", incoming_dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
          <% end %>

          <% if current_user.super_admin? || current_user.admin_officer? || current_user.unit_officer? || current_user.reviewer? %>
            <%= link_to "Daily Logs", log_reports_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
          <% end %>

          <% if current_user.dispatch_officer? || current_user.admin_officer? || current_user.super_admin? %>
            <%= link_to "Dispatch Register", dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "New Dispatch", new_dispatch_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Pending Acknowledgements", pending_acknowledgement_dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Ready to File", ready_to_file_dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Filed Dispatches", filed_dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
          <% end %>

          <% if current_user.super_admin? || current_user.admin_officer? || current_user.reviewer? %>
            <%= link_to "Incidents", incidents_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
            <%= link_to "Reports", reports_dispatches_path, class: "block px-3 py-2 rounded hover:bg-slate-700" %>
          <% end %>
        </nav>

        <div class="px-4 py-4 border-t border-slate-700 text-sm">
          <p class="font-semibold"><%= current_user.display_name %></p>
          <p class="text-slate-300 capitalize mb-3"><%= current_user.role.humanize %></p>

          <%= button_to "Sign Out",
              destroy_user_session_path,
              method: :delete,
              class: "w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium" %>
        </div>
      </aside>
    <% end %>

    <div class="flex min-h-screen">
      <% if user_signed_in? %>
        <!-- Desktop Sidebar -->
        <aside class="desktop-sidebar hidden w-64 min-h-screen bg-slate-900 text-white flex-col flex-shrink-0">
          <div class="px-6 py-6">
            <h1 class="text-lg font-bold">FAAN Admin Ops</h1>
            <p class="text-sm text-slate-300 mt-1">Operations Support System</p>
          </div>

          <nav class="flex-1 px-4 py-4 space-y-2 text-sm overflow-y-auto">
            <%= link_to "Dashboard", dashboard_path, class: nav_link_class(dashboard_path) %>

            <% if current_user.super_admin? || current_user.admin_officer? %>
              <%= link_to "Departments", departments_path, class: nav_link_class(departments_path) %>
              <%= link_to "Units", units_path, class: nav_link_class(units_path) %>
              <%= link_to "Users", users_path, class: nav_link_class(users_path) %>
              <%= link_to "Audit Logs", audit_logs_path, class: nav_link_class(audit_logs_path) %>
            <% end %>

            <% if current_user.unit_officer? %>
              <%= link_to "Incoming Memos", incoming_dispatches_path, class: nav_link_class(incoming_dispatches_path) %>
            <% end %>

            <% if current_user.super_admin? || current_user.admin_officer? || current_user.unit_officer? || current_user.reviewer? %>
              <%= link_to "Daily Logs", log_reports_path, class: nav_link_class(log_reports_path) %>
            <% end %>

            <% if current_user.dispatch_officer? || current_user.admin_officer? || current_user.super_admin? %>
              <%= link_to "Dispatch Register", dispatches_path, class: nav_link_class(dispatches_path) %>
              <%= link_to "New Dispatch", new_dispatch_path, class: nav_link_class(new_dispatch_path) %>
              <%= link_to "Pending Acknowledgements", pending_acknowledgement_dispatches_path, class: nav_link_class(pending_acknowledgement_dispatches_path) %>
              <%= link_to "Ready to File", ready_to_file_dispatches_path, class: nav_link_class(ready_to_file_dispatches_path) %>
              <%= link_to "Filed Dispatches", filed_dispatches_path, class: nav_link_class(filed_dispatches_path) %>
            <% end %>

            <% if current_user.super_admin? || current_user.admin_officer? || current_user.reviewer? %>
              <%= link_to "Incidents", incidents_path, class: nav_link_class(incidents_path) %>
              <%= link_to "Reports", reports_dispatches_path, class: nav_link_class(reports_dispatches_path) %>
            <% end %>
          </nav>

          <div class="px-4 py-4 border-t border-slate-700 text-sm">
            <p class="font-semibold"><%= current_user.display_name %></p>
            <p class="text-slate-300 capitalize"><%= current_user.role.humanize %></p>

            <div class="mt-4">
              <%= button_to "Sign Out",
                  destroy_user_session_path,
                  method: :delete,
                  class: "w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium" %>
            </div>
          </div>
        </aside>
      <% end %>

      <main class="flex-1 min-w-0">
        <% if user_signed_in? %>
          <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
            <h2 class="text-lg md:text-xl font-semibold">
              <%= content_for?(:page_title) ? yield(:page_title) : "FAAN Admin Operations System" %>
            </h2>

            <% if content_for?(:page_subtitle) %>
              <p class="text-sm text-gray-500 mt-1"><%= yield(:page_subtitle) %></p>
            <% end %>
          </header>
        <% end %>

        <div class="px-4 md:px-6 py-6">
          <% flash.each do |type, message| %>
            <div class="<%= flash_class(type) %> mb-4 px-4 py-3 border text-sm">
              <%= message %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    </div>

    <script>
      function setupMobileMenu() {
        const button = document.getElementById("mobile-menu-button");
        const closeButton = document.getElementById("mobile-menu-close");
        const sidebar = document.getElementById("mobile-sidebar");
        const overlay = document.getElementById("mobile-overlay");

        if (!button || !closeButton || !sidebar || !overlay) return;

        function openMenu() {
          sidebar.classList.remove("-translate-x-full");
          overlay.classList.remove("hidden");
        }

        function closeMenu() {
          sidebar.classList.add("-translate-x-full");
          overlay.classList.add("hidden");
        }

        button.onclick = openMenu;
        closeButton.onclick = closeMenu;
        overlay.onclick = closeMenu;

        window.onresize = function () {
          if (window.innerWidth >= 768) closeMenu();
        };
      }

      document.addEventListener("DOMContentLoaded", setupMobileMenu);
      document.addEventListener("turbo:load", setupMobileMenu);
    </script>
  </body>
</html>