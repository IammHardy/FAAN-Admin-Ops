<% content_for :page_title, @incident.incident_number %>
<% content_for :page_subtitle, "Incident details and actions." %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 bg-white border border-gray-200 p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <dt class="text-sm font-semibold text-gray-500">Incident Number</dt>
        <dd class="mt-1 text-sm"><%= @incident.incident_number %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Status</dt>
        <dd class="mt-1 text-sm"><%= @incident.status.humanize %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Title</dt>
        <dd class="mt-1 text-sm"><%= @incident.title %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Description</dt>
        <dd class="mt-1 text-sm text-gray-700"><%= @incident.description %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Incident Type</dt>
        <dd class="mt-1 text-sm"><%= @incident.incident_type.humanize %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Severity</dt>
        <dd class="mt-1 text-sm"><%= @incident.severity.humanize %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Created By</dt>
        <dd class="mt-1 text-sm"><%= @incident.created_by.display_name %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Reviewed By</dt>
        <dd class="mt-1 text-sm"><%= @incident.reviewed_by&.display_name || "-" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Escalation Required</dt>
        <dd class="mt-1 text-sm"><%= @incident.escalation_required? ? "Yes" : "No" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Escalated To</dt>
        <dd class="mt-1 text-sm"><%= @incident.escalated_to.presence || "-" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Escalated At</dt>
        <dd class="mt-1 text-sm"><%= @incident.escalated_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Created At</dt>
        <dd class="mt-1 text-sm"><%= @incident.created_at.strftime("%d %b %Y, %I:%M %p") %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Action Taken</dt>
        <dd class="mt-1 text-sm text-gray-700"><%= @incident.action_taken.presence || "No action recorded." %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Reviewer Remark</dt>
        <dd class="mt-1 text-sm text-gray-700"><%= @incident.reviewer_remark.presence || "No reviewer remark provided." %></dd>
      </div>
    </dl>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <%= link_to "Edit", edit_incident_path(@incident), class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 text-sm font-medium" %>
      <%= link_to "Print", print_incident_path(@incident), class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
      <%= link_to "Back", incidents_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  </div>

  <div class="space-y-6">
    <div class="bg-white border border-gray-200 p-6">
      <h3 class="text-base font-semibold mb-4">Incident Actions</h3>

      <div class="space-y-4">
        <% unless @incident.under_review? || @incident.escalated? || @incident.resolved? || @incident.closed? %>
          <%= form_with url: review_incident_path(@incident), method: :patch, local: true, class: "space-y-3" do %>
            <div>
              <label class="block text-sm font-medium mb-1">Review Remark</label>
              <%= text_area_tag :reviewer_remark, nil, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
            </div>
            <%= submit_tag "Mark as Under Review", class: "w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 text-sm font-medium" %>
          <% end %>
        <% end %>

        <% unless @incident.escalated? || @incident.resolved? || @incident.closed? %>
          <div class="border border-gray-200 p-4">
            <%= form_with url: escalate_incident_path(@incident), method: :patch, local: true, class: "space-y-3" do %>
              <div>
                <label class="block text-sm font-medium mb-1">Escalated To</label>
                <%= text_field_tag :escalated_to, nil, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
              </div>

              <div>
                <label class="block text-sm font-medium mb-1">Reviewer Remark</label>
                <%= text_area_tag :reviewer_remark, nil, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
              </div>

              <%= submit_tag "Escalate Incident", class: "w-full bg-red-600 hover:bg-red-700 text-white px-4 py-2 text-sm font-medium" %>
            <% end %>
          </div>
        <% end %>

        <% unless @incident.resolved? || @incident.closed? %>
          <%= form_with url: resolve_incident_path(@incident), method: :patch, local: true, class: "space-y-3" do %>
            <div>
              <label class="block text-sm font-medium mb-1">Resolution Remark</label>
              <%= text_area_tag :reviewer_remark, nil, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
            </div>

            <%= submit_tag "Mark as Resolved", class: "w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 text-sm font-medium" %>
          <% end %>
        <% end %>

        <% unless @incident.closed? %>
          <%= form_with url: close_incident_path(@incident), method: :patch, local: true, class: "space-y-3" do %>
            <div>
              <label class="block text-sm font-medium mb-1">Closing Remark</label>
              <%= text_area_tag :reviewer_remark, nil, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
            </div>

            <%= submit_tag "Close Incident", class: "w-full bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="bg-white border border-gray-200 p-6">
      <h3 class="text-base font-semibold mb-3">Related Records</h3>

      <div class="space-y-2 text-sm">
        <p>
          <span class="font-medium">Log Report:</span>
          <%= link_to "View Log Report", log_report_path(@incident.log_report), class: "text-blue-600 hover:underline" %>
        </p>

        <p>
          <span class="font-medium">Source Log Entry:</span>
          Logged at <%= @incident.log_entry.entry_time&.strftime("%I:%M %p") || "-" %>
        </p>
      </div>
    </div>
  </div>
</div>