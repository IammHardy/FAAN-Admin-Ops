<% content_for :page_title, "Unit Officer Dashboard" %>
<% content_for :page_subtitle, "Manage daily log reports for your unit." %>

<% if @today_log.present? && @today_log.draft? %>
  <div class="mb-4 bg-amber-50 border border-amber-300 text-amber-800 px-4 py-3">
    ⚠️ You have not submitted today’s log report.
          <%= link_to "Submit Now",
    submit_log_report_path(@today_log),
    data: { turbo_method: :patch, turbo_confirm: "Submit this log?" },
    class: "ml-3 underline font-medium" %>
  </div>
<% end %>

<div class="app-card mb-6">
  <div class="app-card-body">
    <div class="flex items-center justify-between mb-4">
      <h3 class="app-section-title">Incoming Dispatches</h3>
    </div>

    <% if @incoming_dispatches.any? %>
      <div class="space-y-3">
       <% @incoming_dispatches.each do |recipient| %>
  <% dispatch = recipient.dispatch %>
          <div class="border-b border-slate-100 pb-3 last:border-b-0">
            <p class="font-medium">
              <%= link_to dispatch.reference_number,
                  dispatch_path(dispatch),
                  class: "hover:underline" %>
            </p>

            <p class="text-sm text-slate-600">
              <%= dispatch.subject %>
            </p>

            <p class="text-xs text-slate-500 mt-1">
              From:
              <%= dispatch.sender_unit&.name || dispatch.sender_department.name %>
              • Status:
              <%= recipient.status.humanize %>
            </p>

            <div class="flex flex-wrap gap-3 mt-2">
              <%= link_to "View Memo",
                  dispatch_path(dispatch),
                  class: "text-sm text-blue-600 hover:underline" %>

              <% if recipient.dispatched? %>
                <%= button_to "Receive",
                    mark_received_dispatch_path(dispatch),
                    method: :patch,
                    params: {
                      receiver_name: current_user.display_name,
                      receiver_designation: current_user.role.humanize
                    },
                    data: { turbo_confirm: "Confirm that you received this dispatch?" },
                    class: "text-sm text-green-700 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
              <% end %>

              <% if recipient.received? %>
                <%= button_to "Acknowledge",
                    mark_acknowledged_dispatch_path(dispatch),
                    method: :patch,
                    params: {
                      acknowledgement_note: "Acknowledged by #{current_user.display_name}"
                    },
                    data: { turbo_confirm: "Acknowledge this dispatch?" },
                    class: "text-sm text-purple-700 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="app-muted">No incoming dispatches for your unit.</p>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="app-stat-card">
    <p class="app-stat-label">Draft Logs</p>
    <h3 class="app-stat-value"><%= @draft_logs.count %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Submitted Logs</p>
    <h3 class="app-stat-value"><%= @submitted_logs.count %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Reviewed Logs</p>
    <h3 class="app-stat-value"><%= @reviewed_logs.count %></h3>
  </div>
</div>

<div class="app-card mb-6">
  <div class="app-card-body">
    <div class="flex items-center justify-between mb-4">
      <h3 class="app-section-title">Today's Log</h3>
      <%= link_to "View All Logs", log_reports_path, class: "text-sm text-amber-700 hover:underline" %>
    </div>

    <% if @today_log.present? %>
      <p class="text-sm text-slate-600 mb-2">
        Status:
        <strong><%= @today_log.status.humanize %></strong>
      </p>

      <div class="flex gap-3">
        <%= link_to "Continue Today's Log", log_report_path(@today_log), class: "text-blue-600 hover:underline" %>

        <% if @today_log.draft? %>
          <%= link_to "Edit Report Details", edit_log_report_path(@today_log), class: "text-amber-600 hover:underline" %>
        <% end %>
      </div>
    <% else %>
      <p class="app-muted mb-3">No log report has been created for today.</p>

      <%= link_to "Create Today's Log",
          new_log_report_path,
          class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="app-card">
    <div class="app-card-body">
      <h3 class="app-section-title mb-4">Draft Logs</h3>

      <% if @draft_logs.any? %>
        <div class="space-y-3">
          <% @draft_logs.each do |log| %>
            <div class="border-b border-slate-100 pb-3 last:border-b-0">
              <p class="font-medium">
                <%= link_to "#{log.report_date.strftime('%d %b %Y')} - #{log.shift.humanize}",
                    log_report_path(log),
                    class: "hover:underline" %>
              </p>

              <p class="text-xs text-slate-500 mt-1">
                <%= log.unit.name %> • Draft
              </p>

              <%= link_to "Edit",
                  edit_log_report_path(log),
                  class: "text-sm text-amber-600 hover:underline" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="app-muted">No draft logs.</p>
      <% end %>
    </div>
  </div>

  <div class="app-card">
    <div class="app-card-body">
      <h3 class="app-section-title mb-4">Submitted Logs</h3>

      <% if @submitted_logs.any? %>
        <div class="space-y-3">
          <% @submitted_logs.each do |log| %>
            <div class="border-b border-slate-100 pb-3 last:border-b-0">
              <p class="font-medium">
                <%= link_to "#{log.report_date.strftime('%d %b %Y')} - #{log.shift.humanize}",
                    log_report_path(log),
                    class: "hover:underline" %>
              </p>

              <p class="text-xs text-slate-500 mt-1">
                <%= log.unit.name %> • Submitted
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="app-muted">No submitted logs.</p>
      <% end %>
    </div>
  </div>
</div>

<div class="app-card mt-6">
  <div class="app-card-body">
    <h3 class="app-section-title mb-4">Recently Reviewed Logs</h3>

    <% if @reviewed_logs.any? %>
      <div class="space-y-3">
        <% @reviewed_logs.each do |log| %>
          <div class="border-b border-slate-100 pb-3 last:border-b-0">
            <p class="font-medium">
              <%= link_to "#{log.report_date.strftime('%d %b %Y')} - #{log.shift.humanize}",
                  log_report_path(log),
                  class: "hover:underline" %>
            </p>

            <p class="text-xs text-slate-500 mt-1">
              <%= log.unit.name %> • Reviewed
            </p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="app-muted">No reviewed logs yet.</p>
    <% end %>
  </div>
</div>