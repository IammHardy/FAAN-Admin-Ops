<% content_for :page_title, "HOD Review Dashboard" %>
<% content_for :page_subtitle, "Review submitted log reports and generate reports." %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="app-stat-card">
    <p class="app-stat-label">Pending Reviews</p>
    <h3 class="app-stat-value"><%= @pending_review_count %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Reviewed Reports</p>
    <h3 class="app-stat-value"><%= @reviewed_reports_count %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Log Reports Today</p>
    <h3 class="app-stat-value"><%= @log_reports_today %></h3>
  </div>
</div>

<div class="app-card mb-6">
  <div class="app-card-body">
    <div class="flex items-center justify-between mb-4">
      <h3 class="app-section-title">Pending Reports for Review</h3>
      <%= link_to "View All Reports", reports_log_reports_path, class: "text-sm text-amber-700 hover:underline" %>
    </div>

    <% if @pending_reviews.any? %>
      <div class="space-y-3">
        <% @pending_reviews.each do |report| %>
          <div class="border-b border-slate-100 pb-3 last:border-b-0">
            <p class="font-medium">
              <%= link_to "#{report.unit.name} Log", log_report_path(report), class: "hover:underline" %>
            </p>

            <p class="text-sm text-slate-600">
              <%= report.department.name %> • <%= report.unit.name %>
            </p>

            <p class="text-xs text-slate-500 mt-1">
              <%= report.report_date&.strftime("%d %b %Y") %> • <%= report.shift.humanize %>
            </p>

            <div class="flex gap-3 mt-2">
              <%= link_to "View", log_report_path(report), class: "text-sm text-blue-600 hover:underline" %>

              <%= link_to "Review",
                  review_log_report_path(report),
                  data: { turbo_method: :patch, turbo_confirm: "Mark this report as reviewed?" },
                  class: "text-sm text-green-700 hover:underline" %>

              <%= link_to "Print",
                  print_log_report_path(report),
                  target: "_blank",
                  class: "text-sm text-slate-700 hover:underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="app-muted">No pending reports for review.</p>
    <% end %>
  </div>
</div>