<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "Overview of dispatches, log reports, and incidents." %>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-6">
  <div class="app-stat-card">
    <p class="app-stat-label">Dispatches Today</p>
    <h3 class="app-stat-value"><%= @dispatches_today %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Pending Dispatches</p>
    <h3 class="app-stat-value"><%= @pending_dispatches %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Log Reports Today</p>
    <h3 class="app-stat-value"><%= @log_reports_today %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Incidents Today</p>
    <h3 class="app-stat-value"><%= @incidents_today %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Open Incidents</p>
    <h3 class="app-stat-value"><%= @open_incidents %></h3>
  </div>

  <div class="app-stat-card">
    <p class="app-stat-label">Escalated Incidents</p>
    <h3 class="app-stat-value"><%= @escalated_incidents %></h3>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="app-card">
    <div class="app-card-body">
      <div class="flex items-center justify-between mb-4">
        <h3 class="app-section-title">Recent Dispatches</h3>
        <%= link_to "View All", dispatches_path, class: "text-sm text-amber-700 hover:underline" %>
      </div>

      <% if @recent_dispatches.any? %>
        <div class="space-y-3">
          <% @recent_dispatches.each do |dispatch| %>
            <div class="border-b border-slate-100 pb-3 last:border-b-0">
              <p class="font-medium">
                <%= link_to dispatch.reference_number, dispatch_path(dispatch), class: "hover:underline" %>
              </p>
              <p class="text-sm text-slate-600"><%= dispatch.subject %></p>
              <p class="text-xs text-slate-500 mt-1">
                <%= dispatch.memo_date&.strftime("%d %b %Y") %> • <%= dispatch.status.humanize %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="app-muted">No dispatch records yet.</p>
      <% end %>
    </div>
  </div>

  <div class="app-card">
    <div class="app-card-body">
      <div class="flex items-center justify-between mb-4">
        <h3 class="app-section-title">Recent Log Reports</h3>
        <%= link_to "View All", log_reports_path, class: "text-sm text-amber-700 hover:underline" %>
      </div>

      <% if @recent_log_reports.any? %>
        <div class="space-y-3">
          <% @recent_log_reports.each do |report| %>
            <div class="border-b border-slate-100 pb-3 last:border-b-0">
              <p class="font-medium">
                <%= link_to "#{report.unit.name} Log", log_report_path(report), class: "hover:underline" %>
              </p>
              <p class="text-sm text-slate-600"><%= report.department.name %> • <%= report.unit.name %></p>
              <p class="text-xs text-slate-500 mt-1">
                <%= report.report_date&.strftime("%d %b %Y") %> • <%= report.shift.humanize %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="app-muted">No log reports yet.</p>
      <% end %>
    </div>
  </div>

  <div class="mt-6 bg-white border border-gray-200 p-5">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-base font-semibold">Recent Activity</h3>
    <% if current_user.super_admin? || current_user.admin_officer? %>
      <%= link_to "View Audit Logs", audit_logs_path, class: "text-sm text-blue-600 hover:underline" %>
    <% end %>
  </div>

  <% if @recent_audit_logs.any? %>
    <div class="space-y-3">
      <% @recent_audit_logs.each do |log| %>
        <div class="border-b border-gray-100 pb-3 last:border-b-0">
          <p class="text-sm font-medium"><%= log.description %></p>
          <p class="text-xs text-gray-500 mt-1">
            <%= log.user.display_name %> • <%= log.created_at.strftime("%d %b %Y, %I:%M %p") %>
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">No recent activity found.</p>
  <% end %>
</div>

  <div class="app-card">
    <div class="app-card-body">
      <div class="flex items-center justify-between mb-4">
        <h3 class="app-section-title">Recent Incidents</h3>
        <%= link_to "View All", incidents_path, class: "text-sm text-amber-700 hover:underline" %>
      </div>

      <% if @recent_incidents.any? %>
        <div class="space-y-3">
          <% @recent_incidents.each do |incident| %>
            <div class="border-b border-slate-100 pb-3 last:border-b-0">
              <p class="font-medium">
                <%= link_to incident.incident_number, incident_path(incident), class: "hover:underline" %>
              </p>
              <p class="text-sm text-slate-600"><%= incident.title %></p>
              <p class="text-xs text-slate-500 mt-1">
                <%= incident.severity.humanize %> • <%= incident.status.humanize %>
              </p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="app-muted">No incidents recorded yet.</p>
      <% end %>
    </div>
  </div>
</div>