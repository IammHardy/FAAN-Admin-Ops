<%= render "reports/nav" %>
<% content_for :page_title, "Dispatch Reports" %>
<% content_for :page_subtitle, "Filter and review dispatch records." %>

<div class="bg-white border border-gray-200 p-4 mb-4">
  <%= form_with url: reports_dispatches_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-4 gap-4" do %>
    <div>
      <label class="block text-sm font-medium mb-1">From</label>
      <%= date_field_tag :from, params[:from], class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">To</label>
      <%= date_field_tag :to, params[:to], class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Status</label>
      <%= select_tag :status,
          options_for_select(Dispatch.statuses.keys.map { |status| [status.humanize, status] }, params[:status]),
          include_blank: "All Statuses",
          class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex items-end gap-2">
      <%= submit_tag "Filter", class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
      <%= link_to "Reset", reports_dispatches_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="bg-white border border-gray-200 p-5">
    <p class="text-sm text-gray-500">Total Dispatches</p>
    <h3 class="text-2xl font-bold mt-2"><%= @dispatches.count %></h3>
  </div>

  <div class="bg-white border border-gray-200 p-5">
    <p class="text-sm text-gray-500">Dispatched</p>
    <h3 class="text-2xl font-bold mt-2"><%= @dispatches.select(&:dispatched?).count %></h3>
  </div>

  <div class="bg-white border border-gray-200 p-5">
    <p class="text-sm text-gray-500">Received / Filed</p>
    <h3 class="text-2xl font-bold mt-2"><%= @dispatches.count { |d| d.received? || d.acknowledged? || d.filed? } %></h3>
  </div>
</div>

<div class="bg-white border border-gray-200 overflow-x-auto">
  <% if @dispatches.any? %>
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold">Reference No.</th>
          <th class="text-left px-4 py-3 font-semibold">Subject</th>
          <th class="text-left px-4 py-3 font-semibold">Memo Date</th>
          <th class="text-left px-4 py-3 font-semibold">From</th>
          <th class="text-left px-4 py-3 font-semibold">To</th>
          <th class="text-left px-4 py-3 font-semibold">Status</th>
          <th class="text-right px-4 py-3 font-semibold">View</th>
        </tr>
      </thead>
      <tbody>
        <% @dispatches.each do |dispatch| %>
          <tr class="border-b border-gray-100">
            <td class="px-4 py-3"><%= dispatch.reference_number %></td>
            <td class="px-4 py-3"><%= dispatch.subject %></td>
            <td class="px-4 py-3"><%= dispatch.memo_date&.strftime("%d %b %Y") %></td>
            <td class="px-4 py-3"><%= dispatch.sender_department.name %></td>
            <td class="px-4 py-3"><%= dispatch.receiving_department.name %></td>
            <td class="px-4 py-3"><%= dispatch.status.humanize %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to "Open", dispatch_path(dispatch), class: "text-blue-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="p-6 text-sm text-gray-500">No dispatch records found for this filter.</div>
  <% end %>
  <div class="mt-6">
  <%= paginate @dispatches %>
</div>
</div>