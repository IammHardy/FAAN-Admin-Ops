<%= form_with model: @user, class: "space-y-5" do |f| %>
  <% if @user.errors.any? %>
    <div class="border border-red-300 bg-red-50 p-4 text-sm text-red-800">
      <p class="font-semibold mb-2">Please fix the following errors:</p>
      <ul class="list-disc ml-5 space-y-1">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= f.label :full_name, class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :full_name, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium mb-1" %>
      <%= f.email_field :email, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :phone_number, class: "block text-sm font-medium mb-1" %>
      <%= f.telephone_field :phone_number, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :role, class: "block text-sm font-medium mb-1" %>
      <%= f.select :role,
          User.roles.keys.map { |role| [role.humanize, role] },
          { prompt: "Select Role" },
          class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :department_id, "Department", class: "block text-sm font-medium mb-1" %>
      <%= f.collection_select :department_id, @departments, :id, :name,
          { prompt: "Select Department" },
          { class: "w-full border border-gray-300 px-3 py-2 text-sm" } %>
    </div>

    <div>
      <%= f.label :unit_id, "Unit", class: "block text-sm font-medium mb-1" %>
      <%= f.collection_select :unit_id, @units, :id, :name,
          { prompt: "Select Unit" },
          { class: "w-full border border-gray-300 px-3 py-2 text-sm" } %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
      <% if @user.persisted? %>
        <p class="text-xs text-gray-500 mt-1">Leave blank if you do not want to change the password.</p>
      <% end %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium mb-1" %>
      <%= f.password_field :password_confirmation, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :active, class: "border-gray-300" %>
    <%= f.label :active, "Active", class: "text-sm font-medium" %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
    <%= link_to "Cancel", users_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>
<% end %>