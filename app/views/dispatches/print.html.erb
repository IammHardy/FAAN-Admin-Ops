<div class="max-w-4xl mx-auto">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold">FAAN Admin Operations System</h1>
    <p class="text-sm mt-2">Dispatch Record</p>
  </div>

  <div class="border border-gray-300">
    <table class="w-full text-sm border-collapse">
      <tbody>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 w-1/3 bg-gray-100">Reference Number</th>
          <td class="p-3"><%= @dispatch.reference_number %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Subject</th>
          <td class="p-3"><%= @dispatch.subject %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Memo Date</th>
          <td class="p-3"><%= @dispatch.memo_date&.strftime("%d %b %Y") %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Sender Department</th>
          <td class="p-3"><%= @dispatch.sender_department.name %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Sender Unit</th>
          <td class="p-3"><%= @dispatch.sender_unit&.name || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Receiving Department</th>
          <td class="p-3"><%= @dispatch.receiving_department.name %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Receiving Unit</th>
          <td class="p-3"><%= @dispatch.receiving_unit&.name || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Status</th>
          <td class="p-3"><%= @dispatch.status.humanize %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Dispatched By</th>
          <td class="p-3"><%= @dispatch.dispatched_by&.display_name || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Dispatched At</th>
          <td class="p-3"><%= @dispatch.dispatched_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Receiver Name</th>
          <td class="p-3"><%= @dispatch.receiver_name.presence || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Receiver Designation</th>
          <td class="p-3"><%= @dispatch.receiver_designation.presence || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Received At</th>
          <td class="p-3"><%= @dispatch.received_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
        </tr>
        <tr class="border-b border-gray-300">
          <th class="text-left p-3 bg-gray-100">Delivery Note</th>
          <td class="p-3"><%= @dispatch.delivery_note.presence || "-" %></td>
        </tr>
        <tr>
          <th class="text-left p-3 bg-gray-100">Remarks</th>
          <td class="p-3"><%= @dispatch.remarks.presence || "-" %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="mt-8 text-sm">
    <p><strong>Printed On:</strong> <%= Time.current.strftime("%d %b %Y, %I:%M %p") %></p>
  </div>
</div>