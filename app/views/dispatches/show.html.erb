<% content_for :page_title, @dispatch.reference_number %>
<% content_for :page_subtitle, "Dispatch record details." %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 bg-white border border-gray-200 p-6">
    <dl class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <dt class="text-sm font-semibold text-gray-500">Reference Number</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.reference_number %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Status</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.status.humanize %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Subject</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.subject %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Memo Date</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.memo_date&.strftime("%d %b %Y") %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Created By</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.created_by.display_name %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Sender Department</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.sender_department.name %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Sender Unit</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.sender_unit&.name || "-" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Receiving Department</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.receiving_department.name %></dd>
      </div>

      

      <div>
        <dt class="text-sm font-semibold text-gray-500">Dispatched By</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.dispatched_by&.display_name || "-" %></dd>
      </div>

      <div>
        <dt class="text-sm font-semibold text-gray-500">Dispatched At</dt>
        <dd class="mt-1 text-sm"><%= @dispatch.dispatched_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></dd>
      </div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Delivery Note</dt>
        <dd class="mt-1 text-sm text-gray-700"><%= @dispatch.delivery_note.presence || "No delivery note provided." %></dd>
      </div>

      <div class="md:col-span-2">
  <dt class="text-sm font-semibold text-gray-500">Attached Memo Copy</dt>
  <dd class="mt-1 text-sm text-gray-700">
    <% if @dispatch.memo_file.attached? %>
      <%= link_to @dispatch.memo_file.filename.to_s,
          rails_blob_path(@dispatch.memo_file, disposition: "attachment"),
          class: "text-blue-600 hover:underline" %>
    <% else %>
      No memo copy attached.
    <% end %>
  </dd>
</div>

<div class="md:col-span-2">
  <dt class="text-sm font-semibold text-gray-500 mb-2">Recipient Units</dt>

  <% if @dispatch.dispatch_recipients.any? %>
    <div class="border border-gray-200 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-3 py-2 font-semibold">Unit</th>
            <th class="text-left px-3 py-2 font-semibold">Status</th>
            <th class="text-left px-3 py-2 font-semibold">Received By</th>
            <th class="text-left px-3 py-2 font-semibold">Received At</th>
            <th class="text-left px-3 py-2 font-semibold">Acknowledged By</th>
            <th class="text-left px-3 py-2 font-semibold">Acknowledged At</th>
          </tr>
        </thead>

        <tbody>
          <% @dispatch.dispatch_recipients.includes(:receiving_unit, :received_by, :acknowledged_by).each do |recipient| %>
            <tr class="border-b border-gray-100">
              <td class="px-3 py-2"><%= recipient.receiving_unit.name %></td>
              <td class="px-3 py-2"><%= recipient.status.humanize %></td>
              <td class="px-3 py-2"><%= recipient.received_by&.display_name || "-" %></td>
              <td class="px-3 py-2"><%= recipient.received_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
              <td class="px-3 py-2"><%= recipient.acknowledged_by&.display_name || "-" %></td>
              <td class="px-3 py-2"><%= recipient.acknowledged_at&.strftime("%d %b %Y, %I:%M %p") || "-" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <dd class="mt-1 text-sm text-gray-700">No recipient units assigned.</dd>
  <% end %>
</div>

<div class="mt-6 bg-white border border-gray-200 p-6">
  <h3 class="text-base font-semibold mb-4">Activity History</h3>

  <% if @audit_logs.any? %>
    <div class="space-y-3">
      <% @audit_logs.each do |log| %>
        <div class="border-b border-gray-100 pb-3 last:border-b-0">
          <p class="text-sm font-medium"><%= log.description %></p>
          <p class="text-xs text-gray-500 mt-1">
            <%= log.user.display_name %> • <%= log.created_at.strftime("%d %b %Y, %I:%M %p") %>
          </p>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-500">No activity history for this dispatch.</p>
  <% end %>
</div>

      <div class="md:col-span-2">
        <dt class="text-sm font-semibold text-gray-500">Remarks</dt>
        <dd class="mt-1 text-sm text-gray-700"><%= @dispatch.remarks.presence || "No remarks provided." %></dd>
      </div>
    </dl>

    <div class="mt-6 flex flex-wrap items-center gap-3">
      <% if can_manage_dispatches? %>
  <%= link_to "Edit", edit_dispatch_path(@dispatch), class: "bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 text-sm font-medium" %>
<% end %>
      <% if can_manage_dispatches? %>
  <%= link_to "Print", print_dispatch_path(@dispatch), class: "bg-slate-900 hover:bg-slate-800 text-white px-4 py-2 text-sm font-medium" %>
<% end %>
      <%= link_to "Back", dashboard_path, class: "border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
  </div>

  
  <div class="bg-white border border-gray-200 p-6">
    <h3 class="text-base font-semibold mb-4">Update Status</h3>
    <% current_recipient = @dispatch.dispatch_recipients.find_by(receiving_unit_id: current_user.unit_id) if current_user.unit_officer? %>

    <div class="space-y-4">
      <% if can_manage_dispatches? && @dispatch.draft? %>
  <%= button_to "Mark as Dispatched",
      mark_dispatched_dispatch_path(@dispatch),
      method: :patch,
      class: "w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 text-sm font-medium" %>
<% end %>

<% if current_user.unit_officer? && current_recipient&.dispatched? %>
  <div class="border border-gray-200 p-4">
    <%= form_with url: mark_received_dispatch_path(@dispatch), method: :patch, local: true, class: "space-y-3" do %>
      <%= hidden_field_tag :receiver_name, current_user.display_name %>
      <%= hidden_field_tag :receiver_designation, current_user.role.humanize %>

      <p class="text-sm text-gray-600">
        Receive as <strong><%= current_user.display_name %></strong>
      </p>

      <%= submit_tag "Receive Dispatch", class: "w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 text-sm font-medium" %>
    <% end %>
  </div>
<% end %>

<% if current_user.unit_officer? && current_recipient&.received? %>
  <%= form_with url: mark_acknowledged_dispatch_path(@dispatch), method: :patch, local: true, class: "space-y-3" do %>
    <div>
      <label class="block text-sm font-medium mb-1">Acknowledgement Note</label>
      <%= text_area_tag :acknowledgement_note, nil, rows: 3, class: "w-full border border-gray-300 px-3 py-2 text-sm" %>
    </div>

    <%= submit_tag "Acknowledge Dispatch", class: "w-full bg-purple-600 hover:bg-purple-700 text-white px-4 py-2 text-sm font-medium" %>
  <% end %>
<% end %>

<% if can_manage_dispatches? && @dispatch.all_recipients_acknowledged? %>
  <%= button_to "Mark as Filed",
      mark_filed_dispatch_path(@dispatch),
      method: :patch,
      class: "w-full bg-amber-600 hover:bg-amber-700 text-white px-4 py-2 text-sm font-medium" %>
<% end %>
    </div>
  </div>
</div>